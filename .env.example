# Pet Center - Environment Configuration
# ─────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# Set file permissions: chmod 600 .env
#
# To generate a strong ADMIN_TOKEN, run in terminal:
#   openssl rand -hex 32
#
# Example output: 7f3a9c1b2e8d4f6a5c9e2b1d3f5a7c9e2b1d3f5a7c9e2b1d3f5a7c9e2b1d3f5a

ADMIN_TOKEN=your_random_secure_token_here
